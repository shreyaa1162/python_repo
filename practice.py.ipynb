      ],
      "source": [
        "n = int(input(\"Enter number: \"))\n",
        "rev = 0\n",
        "\n",
        "while n > 0:\n",
        "    digit = n % 10\n",
        "    rev = rev * 10 + digit\n",
        "    n = n // 10\n",
        "\n",
        "print(\"Reverse =\", rev)"
      ]
    },
    {
